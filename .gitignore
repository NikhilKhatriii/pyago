# Flutter / Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
# pubspec.lock is intentionally NOT ignored for apps (only for packages)
# so that CI produces reproducible builds. Remove this line if you change
# your mind (pub.dev recommends keeping lock for libraries only).

# IDE
.idea/
*.iml
*.ipr
*.iws
# VS Code settings are committed (.vscode/launch.json, extensions.json)
# so team members get the correct launch profiles automatically.
# User-specific overrides live in .vscode/*.code-workspace — ignore those:
.vscode/*.code-workspace

# Android
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/**/GeneratedPluginRegistrant.java
*.jks
key.properties

# iOS
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Pods/
ios/.symlinks/
ios/Runner.xcworkspace/xcshareddata/
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
DerivedData/

# macOS
.DS_Store

# ── Pyago-specific ──────────────────────────────────────────────────────────

# Staging and production dart-defines may contain real API keys.
# Only .dart_defines/dev.json is safe to commit.
.dart_defines/staging.json
.dart_defines/production.json

# Coverage reports (generated by flutter test --coverage)
coverage/

# Golden test baselines are committed so CI can diff them.
# Do NOT ignore test/golden/goldens/

# Debug symbols from obfuscated release builds
build/debug-symbols/
